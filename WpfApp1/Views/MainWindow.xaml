<Window x:Class="CryptoViewer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Crypto Viewer"
        Height="600"
        Width="900"
        Background="{DynamicResource BgBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Background="{DynamicResource SidebarBrush}">
            <TextBlock Text="{DynamicResource AppTitle}"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontSize="14"
                       FontWeight="Bold"
                       Margin="16,24,16,32"/>

            <Button Content="{DynamicResource NavHome}"
                    Click="NavHome_Click"
                    Background="Transparent"
                    Foreground="{DynamicResource TextSecondaryBrush}"
                    BorderThickness="0"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Padding="16,10"
                    Cursor="Hand"/>

            <Button Content="{DynamicResource NavConverter}"
                    Click="NavConverter_Click"
                    Background="Transparent"
                    Foreground="{DynamicResource TextSecondaryBrush}"
                    BorderThickness="0"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Padding="16,10"
                    Cursor="Hand"/>

            <Separator Background="{DynamicResource Surface2Brush}" Margin="16,16"/>

            <Button Content="{DynamicResource BtnTheme}"
                    Click="ToggleTheme_Click"
                    Background="Transparent"
                    Foreground="{DynamicResource TextMutedBrush}"
                    BorderThickness="0"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Padding="16,10"
                    Cursor="Hand"/>

            <Button x:Name="LangButton"
                    Content="{DynamicResource BtnLang}"
                    Click="ToggleLang_Click"
                    Background="Transparent"
                    Foreground="{DynamicResource TextMutedBrush}"
                    BorderThickness="0"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Padding="16,10"
                    Cursor="Hand"/>
        </StackPanel>

        <Frame x:Name="MainFrame"
               Grid.Column="1"
               NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>