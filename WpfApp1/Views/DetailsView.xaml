<Page x:Class="CryptoViewer.Views.DetailsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:oxy="http://oxyplot.org/wpf"
      Background="#121212">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Loading..."
                   Foreground="Gray" FontSize="13"
                   Margin="20,20,0,0"
                   Visibility="{Binding IsLoading,
                       Converter={StaticResource BooleanToVisibilityConverter}}"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">

                <TextBlock Text="{Binding Coin.Name}"
                           FontSize="26" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="{Binding Coin.Symbol}"
                           Foreground="Gray" FontSize="14" Margin="0,2,0,20"/>

                <!-- Stats -->
                <Border Background="#1E1E1E" CornerRadius="8"
                        Padding="16" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="PRICE" Foreground="Gray" FontSize="11"/>
                            <TextBlock Text="{Binding Coin.CurrentPrice, StringFormat='${0:N2}'}"
                                       Foreground="White" FontSize="20" FontWeight="Medium"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="24H CHANGE" Foreground="Gray" FontSize="11"/>
                            <TextBlock Text="{Binding Coin.PriceChange24h, StringFormat='{}{0:+0.00;-0.00}%'}"
                                       FontSize="20" FontWeight="Medium">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#22C55E"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Coin.IsPriceChangePositive}" Value="False">
                                                <Setter Property="Foreground" Value="#EF4444"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,0,12">
                            <TextBlock Text="VOLUME 24H" Foreground="Gray" FontSize="11"/>
                            <TextBlock Text="{Binding Coin.TotalVolume, StringFormat='${0:N0}'}"
                                       Foreground="White" FontSize="14"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,0,0,12">
                            <TextBlock Text="MARKET CAP" Foreground="Gray" FontSize="11"/>
                            <TextBlock Text="{Binding Coin.MarketCap, StringFormat='${0:N0}'}"
                                       Foreground="White" FontSize="14"/>
                        </StackPanel>

                        <StackPanel Grid.Column="0" Grid.Row="2">
                            <TextBlock Text="24H HIGH" Foreground="Gray" FontSize="11"/>
                            <TextBlock Text="{Binding Coin.High24h, StringFormat='${0:N2}'}"
                                       Foreground="#22C55E" FontSize="14"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Grid.Row="2">
                            <TextBlock Text="24H LOW" Foreground="Gray" FontSize="11"/>
                            <TextBlock Text="{Binding Coin.Low24h, StringFormat='${0:N2}'}"
                                       Foreground="#EF4444" FontSize="14"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="#1E1E1E" CornerRadius="8" Padding="10" Margin="0,0,0,20">
                    <Grid Height="250">
                        <oxy:PlotView Model="{Binding PlotModel}"
                      Background="Transparent"/>
                    </Grid>
                </Border>

                <!-- Markets -->
                <TextBlock Text="AVAILABLE ON MARKETS"
                           Foreground="Gray" FontSize="11" Margin="0,0,0,10"/>

                <ItemsControl ItemsSource="{Binding Markets}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1E1E1E" CornerRadius="8"
                                    Margin="0,0,0,6" Padding="14,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="White" FontSize="14"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Base}"
                                                       Foreground="Gray" FontSize="12"/>
                                            <TextBlock Text=" / "
                                                       Foreground="Gray" FontSize="12"/>
                                            <TextBlock Text="{Binding Target}"
                                                       Foreground="Gray" FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ConvertedLast.Usd, StringFormat='${0:N4}'}"
                                               Foreground="White" FontSize="14"
                                               VerticalAlignment="Center"
                                               Margin="16,0"/>

                                    <Button Content="Trade →"
                                                Command="{Binding DataContext.OpenTradeCommand,
                                                    RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding TradeUrl}"
                                                Foreground="Gray"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>