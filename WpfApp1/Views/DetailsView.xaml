<Page x:Class="CryptoViewer.Views.DetailsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#121212">

    <Grid Margin="20">

        <StackPanel>

            <TextBlock Text="{Binding Coin.Name}"
                       FontSize="26"
                       Foreground="White"
                       FontWeight="Bold"/>

            <TextBlock Text="{Binding Coin.Symbol}"
                       Foreground="Gray"
                       FontSize="16"
                       Margin="0,0,0,20"/>

            <TextBlock Text="{Binding Coin.CurrentPrice, StringFormat=Price: {0:F2} $}"
                       Foreground="White"/>

            <TextBlock Text="{Binding Coin.MarketCap, StringFormat=Market Cap: {0}}"
                       Foreground="White"/>

            <TextBlock Text="{Binding Coin.TotalVolume, StringFormat=Volume: {0}}"
                       Foreground="White"/>

            <TextBlock Text="{Binding Coin.High24h, StringFormat=24h High: {0:F2}}"
                       Foreground="LightGreen"/>

            <TextBlock Text="{Binding Coin.Low24h, StringFormat=24h Low: {0:F2}}"
                       Foreground="Red"/>

            <TextBlock Text="{Binding Coin.PriceChange24h, StringFormat=Change: {0:F2}%}"
                       Foreground="Yellow"/>

            <TextBlock Text="Loading..."
                       Foreground="Gray"
                       Visibility="{Binding IsLoading,
                           Converter={StaticResource BooleanToVisibilityConverter}}"/>

        </StackPanel>

    </Grid>
</Page>