<Page x:Class="CryptoViewer.Views.HomeView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#121212">
    <Grid Margin="20">
        <ListView ItemsSource="{Binding Coins}"
                  MouseDoubleClick="Coin_DoubleClick"
                  Background="#121212"
                  BorderThickness="0"
                  Foreground="White">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="#121212"/>
                    <Setter Property="Foreground" Value="White"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0,8">
                        <TextBlock Text="{Binding Name}" Foreground="White" FontSize="16"/>
                        <TextBlock Text="{Binding CurrentPrice, StringFormat='${0:N2}'}" Foreground="#AAAAAA"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>