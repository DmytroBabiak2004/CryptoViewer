<Page x:Class="CryptoViewer.Views.ConverterView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BgBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0"
                Content="{DynamicResource BtnBack}"
                Command="{Binding GoBackCommand}"
                Background="Transparent"
                Foreground="{DynamicResource TextSecondaryBrush}"
                BorderThickness="0"
                Cursor="Hand"
                HorizontalAlignment="Left"
                Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1"
                   Text="{DynamicResource NavConverter}"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   FontSize="26"
                   FontWeight="Bold"
                   Margin="0,0,0,30"/>

        <StackPanel Grid.Row="2">
            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="20">
                <StackPanel>

                    <TextBlock Text="{DynamicResource LabelAmount}"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="11" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"
                             Background="{DynamicResource Surface2Brush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderThickness="0"
                             Padding="10,8"
                             FontSize="16"
                             Margin="0,0,0,20"/>

                    <TextBlock Text="{DynamicResource LabelFrom}"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="11" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding Coins}"
                              SelectedItem="{Binding FromCoin}"
                              Background="{DynamicResource Surface2Brush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderThickness="0"
                              Padding="10,8"
                              FontSize="14"
                              Margin="0,0,0,20">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Symbol}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="13" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontSize="13"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="{DynamicResource LabelTo}"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="11" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding Coins}"
                              SelectedItem="{Binding ToCoin}"
                              Background="{DynamicResource Surface2Brush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderThickness="0"
                              Padding="10,8"
                              FontSize="14"
                              Margin="0,0,0,30">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Symbol}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="13" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontSize="13"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Border Background="{DynamicResource Surface2Brush}" CornerRadius="6" Padding="16">
                        <TextBlock Text="{Binding Result}"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontSize="18"
                                   FontWeight="Medium"
                                   HorizontalAlignment="Center"/>
                    </Border>

                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>