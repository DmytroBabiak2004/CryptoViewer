<Page x:Class="CryptoViewer.Views.ConverterView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#121212">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0"
                Content="← Back"
                Command="{Binding GoBackCommand}"
                Background="Transparent"
                Foreground="Gray"
                BorderThickness="0"
                Cursor="Hand"
                HorizontalAlignment="Left"
                Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1"
                   Text="Converter"
                   Foreground="White"
                   FontSize="26"
                   FontWeight="Bold"
                   Margin="0,0,0,30"/>

        <StackPanel Grid.Row="2">
            <Border Background="#1E1E1E" CornerRadius="8" Padding="20">
                <StackPanel>

                    <TextBlock Text="Amount" Foreground="Gray" FontSize="11" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"
                             Background="#2A2A2A"
                             Foreground="White"
                             BorderThickness="0"
                             Padding="10,8"
                             FontSize="16"
                             Margin="0,0,0,20"/>

                    <TextBlock Text="From" Foreground="Gray" FontSize="11" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding Coins}"
                              SelectedItem="{Binding FromCoin}"
                              Background="#2A2A2A"
                              Foreground="White"
                              BorderThickness="0"
                              Padding="10,8"
                              FontSize="14"
                              Margin="0,0,0,20">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Symbol}" Foreground="Gray" FontSize="13" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="13"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="To" Foreground="Gray" FontSize="11" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding Coins}"
                              SelectedItem="{Binding ToCoin}"
                              Background="#2A2A2A"
                              Foreground="White"
                              BorderThickness="0"
                              Padding="10,8"
                              FontSize="14"
                              Margin="0,0,0,30">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Symbol}" Foreground="Gray" FontSize="13" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="13"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Border Background="#2A2A2A" CornerRadius="6" Padding="16">
                        <TextBlock Text="{Binding Result}"
                                   Foreground="#22C55E"
                                   FontSize="18"
                                   FontWeight="Medium"
                                   HorizontalAlignment="Center"/>
                    </Border>

                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>